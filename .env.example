# Firefly III QA Automation - Environment Configuration
# All credentials are auto-generated by `npm run env:init` into .runtime/
# This file documents optional overrides. Never commit real credentials.

# EU region overrides (defaults: port 8080)
# EU_PORT=8080
# EU_TEST_EMAIL=qa-eu@test.example.com
# EU_TEST_PASSWORD=

# US region overrides (defaults: port 8081)
# US_PORT=8081
# US_TEST_EMAIL=qa-us@test.example.com
# US_TEST_PASSWORD=

# Token overrides (normally loaded from .runtime/*.token.txt)
# FIREFLY_TOKEN_EU=
# FIREFLY_TOKEN_US=
# FIREFLY_TOKEN=

# CI override for unique test data
# CI_RUN=
